{
    "name": "mrh/license",
    "description": "Reusable Laravel 12 licensing client for the MRH / Saudi License Server. Activation, signed daily verification, domain & installation binding, grace period, and a global route-independent guard.",
    "type": "library",
    "license": "proprietary",
    "keywords": ["laravel", "license", "licensing", "activation", "drm"],
    "authors": [
        { "name": "MRH" }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/console": "^12.0",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Mrh\\License\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mrh\\License\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mrh\\License\\LicenseServiceProvider"
            ],
            "aliases": {
                "License": "Mrh\\License\\Facades\\License"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

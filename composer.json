{
    "name": "konok/portfolio-cms",
    "description": "Portfolio CMS - Laravel application with admin panel, blog, projects, and MRH License integration",
    "type": "project",
    "license": "MIT",
    "keywords": ["laravel", "portfolio", "cms"],
    "authors": [
        { "name": "konok-io" }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "guzzlehttp/guzzle": "^7.8",
        "spatie/laravel-permission": "^6.0",
        "unisharp/laravel-filemanager": "^2.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.0",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Mrh\\License\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Mrh\\License\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mrh\\License\\LicenseServiceProvider"
            ],
            "aliases": {
                "License": "Mrh\\License\\Facades\\License"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
